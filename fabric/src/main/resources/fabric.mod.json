{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "${description}",
    "authors": [
        "${mod_author}"
    ],
    "contact": {
        "sources": "https://github.com/Ezzenix/ChatAnimation",
        "homepage": "https://modrinth.com/mod/chatanimation",
        "issues": "https://github.com/Ezzenix/ChatAnimation/issues"
    },
    "license": "${license}",
    "icon": "icon.png",
    "environment": "client",
    "entrypoints": {
        "main": [
            "com.ezzenix.chatanimation.ChatAnimationFabric"
		],
        "modmenu": [
			"com.ezzenix.chatanimation.ModMenuImpl"
		]
    },
    "mixins": [
        "${mod_id}.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=${fabric_loader_version}",
        "minecraft": "~${minecraft_version}",
        "java": ">=${java_version}"
    }
}
  